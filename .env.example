# Public values bundled into the iOS app. These are safe to expose, but each
# developer should use their own Clerk and Convex projects.
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_replace_me
EXPO_PUBLIC_CONVEX_URL=https://replace-me.convex.cloud

# Optional development-only switches. Leave disabled for normal use.
EXPO_PUBLIC_DEV_BYPASS_AUTH=false
EXPO_PUBLIC_SHOW_BACKEND_PROBE=false
EXPO_PUBLIC_DEV_MEMORY_TOKEN_CACHE=false
